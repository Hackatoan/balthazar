# Your Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# Channel ID where clips should be posted if DM is disabled
CLIPS_CHANNEL_ID=

# The port for the web UI
PORT=3000

# The ASR Engine, we use faster-whisper now
ASR_ENGINE=faster-whisper

# Faster-whisper model (e.g., tiny.en, base.en, small.en)
WHISPER_MODEL=base.en

# ASR (speech-to-text) server URL
ASR_URL=http://balthazar-asr:5005/transcribe

# --- /talk conversational voice mode ---

# Piper (text-to-speech) server URL
PIPER_URL=http://balthazar-piper:5006/synthesize

# Brain: Claude is preferred when a token is set (reuses the lamarlive Claude Code
# OAuth token). Falls back to Gemini if no Claude token is present.
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Gemini brain (fallback; free tier is very limited — ~20 req/day on 2.5-flash)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Respond to every utterance (1) vs only when addressed by name / mid-conversation (0)
TALK_ALWAYS_RESPOND=0
# How long after a reply Balthazar keeps answering without needing his name (ms)
TALK_FOLLOWUP_MS=25000
# Rolling conversation turns kept as context
TALK_HISTORY=12
